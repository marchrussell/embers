# Copy to .env.test and fill in values — never commit .env.test

# Supabase project (same as your dev .env.local)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key — allows tests to create/delete rows bypassing RLS
# Get from: Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Test user credentials — create these accounts in your Supabase project
# Admin: must have is_admin = true in the profiles table
TEST_ADMIN_EMAIL=admin-test@example.com
TEST_ADMIN_PASSWORD=your-admin-password

# Member: must have an active subscription row in user_subscriptions
TEST_MEMBER_EMAIL=member-test@example.com
TEST_MEMBER_PASSWORD=your-member-password
